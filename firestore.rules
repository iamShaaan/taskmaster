rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── User Profiles ─────────────────────────────────────────────────────
    // Any authenticated user can READ profiles (invite lookup, display names).
    // Only the profile owner can WRITE their own profile.
    match /apps/{appId}/users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ─── Invitations ───────────────────────────────────────────────────────
    // Anyone can read an invite by token (needed before login to validate).
    // Only authenticated users can create/update invites.
    match /apps/{appId}/invitations/{token} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }

    // ─── Projects (special handling for shared_with) ───────────────────────
    match /apps/{appId}/projects/{docId} {
      // Owner: full access
      allow read, write: if request.auth != null
        && resource != null
        && resource.data.owner_id == request.auth.uid;

      // Shared members: read + create new sub-docs (notes etc.)
      allow read: if request.auth != null
        && resource != null
        && resource.data.shared_with is list
        && request.auth.uid in resource.data.shared_with;

      // ✅ Invite self-acceptance:
      // Allow a user to add ONLY themselves to shared_with if:
      //   1. Their verified Firebase email is in pending_invites
      //   2. The update only adds their UID to shared_with (no other changes to that field)
      //   3. They are not already in shared_with
      allow update: if request.auth != null
        && resource != null
        && resource.data.pending_invites is list
        && request.auth.token.email in resource.data.pending_invites
        && request.resource.data.shared_with is list
        && request.auth.uid in request.resource.data.shared_with
        && !(request.auth.uid in resource.data.shared_with);
    }

    // ─── All other app data (tasks, clients, notes, meetings, actions…) ────
    match /apps/{appId}/{collection}/{docId} {
      // Owner: full access
      allow read, write: if request.auth != null
        && resource != null
        && resource.data.owner_id == request.auth.uid;

      // Shared members: read only
      allow read: if request.auth != null
        && resource != null
        && resource.data.shared_with is list
        && request.auth.uid in resource.data.shared_with;

      // New document creation (resource == null → no owner yet)
      allow create: if request.auth != null && resource == null;
    }

    // ─── Collection-level list (Firestore query support) ───────────────────
    match /apps/{appId}/{collection} {
      allow list: if request.auth != null;
    }
  }
}
