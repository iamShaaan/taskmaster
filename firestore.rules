rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ───────────────────────────────────────────────────
    function isAuthed() {
      return request.auth != null;
    }
    function isOwner(resource) {
      return isAuthed() && resource != null && resource.data.owner_id == request.auth.uid;
    }
    // Docs with null/missing owner_id are "orphaned" — allow any authed user
    // to claim/update/delete them (covers test docs created without auth context)
    function isOrphan(resource) {
      return isAuthed() && resource != null
        && (!('owner_id' in resource.data) || resource.data.owner_id == null);
    }

    // ─── User Profiles ──────────────────────────────────────────────────────
    match /apps/{appId}/users/{userId} {
      allow read: if isAuthed();
      allow write: if isAuthed() && request.auth.uid == userId;
    }

    // ─── Invitations (legacy) ───────────────────────────────────────────────
    match /apps/{appId}/invitations/{token} {
      allow read: if true;
      allow create, update: if isAuthed();
    }

    // ─── Projects (role-based) ──────────────────────────────────────────────
    match /apps/{appId}/projects/{docId} {
      // Owner: full control
      allow read, write, delete: if isOwner(resource);

      // Orphaned docs (no owner_id): any authed user can manage
      allow read, write, delete: if isOrphan(resource);

      // Admin members: full control
      allow read, write, delete: if isAuthed()
        && resource != null
        && resource.data.admin_uids is list
        && request.auth.uid in resource.data.admin_uids;

      // Moderator members: read + create + update (NO delete)
      allow read, create, update: if isAuthed()
        && resource != null
        && resource.data.moderator_uids is list
        && request.auth.uid in resource.data.moderator_uids;

      // Viewer members: read only
      allow read: if isAuthed()
        && resource != null
        && resource.data.viewer_uids is list
        && request.auth.uid in resource.data.viewer_uids;

      // Any member_uids member: read
      allow read: if isAuthed()
        && resource != null
        && resource.data.member_uids is list
        && request.auth.uid in resource.data.member_uids;

      // Create new project
      allow create: if isAuthed() && resource == null;
    }

    // ─── All other app data (tasks, clients, notes, meetings, actions…) ─────
    match /apps/{appId}/{collection}/{docId} {
      // Owner: full access
      allow read, write: if isOwner(resource);

      // Orphaned docs (null/missing owner_id): any authed user can manage
      allow read, write, delete: if isOrphan(resource);

      // Any authenticated user can read (for shared project tasks etc.)
      allow read: if isAuthed();

      // Create new documents
      allow create: if isAuthed() && resource == null;
    }

    // ─── Collection-level list ──────────────────────────────────────────────
    match /apps/{appId}/{collection} {
      allow list: if isAuthed();
    }
  }
}
