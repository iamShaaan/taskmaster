rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ────────────────────────────────────────────────────
    function isAuthed() {
      return request.auth != null;
    }

    function isOwner(resource) {
      return isAuthed()
        && resource != null
        && resource.data.owner_id == request.auth.uid;
    }

    function isOrphan(resource) {
      return isAuthed()
        && resource != null
        && (!('owner_id' in resource.data) || resource.data.owner_id == null);
    }

    // =========================================================================
    // TASK MASTER  (apps/task-master-v1/...)
    // Explicit, per-collection rules. Isolated from other apps by the path.
    // =========================================================================

    // ── User Profiles ─────────────────────────────────────────────────────────
    match /apps/task-master-v1/users/{userId} {
      allow read:  if isAuthed();
      allow write: if isAuthed() && request.auth.uid == userId;
    }

    // ── Invitations ───────────────────────────────────────────────────────────
    match /apps/task-master-v1/invitations/{token} {
      allow read:           if true;
      allow create, update: if isAuthed();
    }

    // ── Projects ──────────────────────────────────────────────────────────────
    match /apps/task-master-v1/projects/{docId} {
      // CREATE — resource is null at creation time, so we allow any authed user
      allow create: if isAuthed();

      // READ — owner, orphan, or any named member role
      allow read: if isOwner(resource)
                  || isOrphan(resource)
                  || (isAuthed() && resource != null && resource.data.admin_uids is list
                      && request.auth.uid in resource.data.admin_uids)
                  || (isAuthed() && resource != null && resource.data.moderator_uids is list
                      && request.auth.uid in resource.data.moderator_uids)
                  || (isAuthed() && resource != null && resource.data.viewer_uids is list
                      && request.auth.uid in resource.data.viewer_uids)
                  || (isAuthed() && resource != null && resource.data.member_uids is list
                      && request.auth.uid in resource.data.member_uids);

      // UPDATE — owner, orphan, admin, or moderator
      allow update: if isOwner(resource)
                    || isOrphan(resource)
                    || (isAuthed() && resource != null && resource.data.admin_uids is list
                        && request.auth.uid in resource.data.admin_uids)
                    || (isAuthed() && resource != null && resource.data.moderator_uids is list
                        && request.auth.uid in resource.data.moderator_uids);

      // DELETE — owner or admin only
      allow delete: if isOwner(resource)
                    || isOrphan(resource)
                    || (isAuthed() && resource != null && resource.data.admin_uids is list
                        && request.auth.uid in resource.data.admin_uids);
    }

    // ── Tasks ─────────────────────────────────────────────────────────────────
    match /apps/task-master-v1/tasks/{docId} {
      // CREATE — any authed user; owner_id is stamped by the client
      allow create: if isAuthed();

      // READ — any authed user (tasks can be shared across projects)
      allow read: if isAuthed();

      // UPDATE — owner, orphan, or assignee
      allow update: if isOwner(resource)
                    || isOrphan(resource)
                    || (isAuthed() && resource != null
                        && resource.data.assignee_id == request.auth.uid);

      // DELETE (hard purge) — owner or orphan only
      allow delete: if isOwner(resource) || isOrphan(resource);
    }

    // ── Routines ──────────────────────────────────────────────────────────────
    match /apps/task-master-v1/routines/{docId} {
      allow create:        if isAuthed();
      allow read:          if isAuthed();
      allow update, delete: if isOwner(resource) || isOrphan(resource);
    }

    // ── Daily Logs ────────────────────────────────────────────────────────────
    match /apps/task-master-v1/daily_logs/{docId} {
      allow create:        if isAuthed();
      allow read:          if isAuthed();
      allow update, delete: if isOwner(resource) || isOrphan(resource);
    }

    // ── All other task-master-v1 collections (clients, notes, meetings…) ──────
    match /apps/task-master-v1/{collection}/{docId} {
      allow create:        if isAuthed();
      allow read:          if isAuthed();
      allow update, delete: if isOwner(resource) || isOrphan(resource);
    }

    // ── Collection-level list queries ─────────────────────────────────────────
    match /apps/task-master-v1/{collection} {
      allow list: if isAuthed();
    }

    // =========================================================================
    // OTHER APPS (Profluencer, CRM-Tool, etc.)
    // These rules will NOT affect task-master-v1 paths (different match prefix).
    // When Profluencer deploys its own rules they go here, keeping TM safe.
    // =========================================================================
    match /apps/{appId}/users/{userId} {
      allow read:  if isAuthed();
      allow write: if isAuthed() && request.auth.uid == userId;
    }

    match /apps/{appId}/{collection}/{docId} {
      allow create:        if isAuthed();
      allow read:          if isAuthed();
      allow update, delete: if isAuthed()
                            && (resource == null
                                || !('owner_id' in resource.data)
                                || resource.data.owner_id == null
                                || resource.data.owner_id == request.auth.uid);
    }

    match /apps/{appId}/{collection} {
      allow list: if isAuthed();
    }

  }
}
