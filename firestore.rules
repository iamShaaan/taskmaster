rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── User Profiles ─────────────────────────────────────────────────────
    // Any authenticated user can READ profiles (user_code lookup, display names).
    // Only the profile owner can WRITE their own profile.
    match /apps/{appId}/users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ─── Invitations (legacy) ──────────────────────────────────────────────
    // Kept for any existing invite tokens still in the DB.
    match /apps/{appId}/invitations/{token} {
      allow read: if true;
      allow create, update: if request.auth != null;
    }

    // ─── Projects (role-based) ─────────────────────────────────────────────
    match /apps/{appId}/projects/{docId} {
      // Owner: full control
      allow read, write, delete: if request.auth != null
        && resource != null
        && resource.data.owner_id == request.auth.uid;

      // Admin members: full control (same as owner)
      allow read, write, delete: if request.auth != null
        && resource != null
        && resource.data.admin_uids is list
        && request.auth.uid in resource.data.admin_uids;

      // Moderator members: read + create + update (NO delete)
      allow read, create, update: if request.auth != null
        && resource != null
        && resource.data.moderator_uids is list
        && request.auth.uid in resource.data.moderator_uids;

      // Viewer members: read only
      allow read: if request.auth != null
        && resource != null
        && resource.data.viewer_uids is list
        && request.auth.uid in resource.data.viewer_uids;

      // Allow read via member_uids (catch-all for any member)
      allow read: if request.auth != null
        && resource != null
        && resource.data.member_uids is list
        && request.auth.uid in resource.data.member_uids;

      // Create new project (no resource yet)
      allow create: if request.auth != null && resource == null;
    }

    // ─── All other app data (tasks, clients, notes, meetings, actions…) ────
    match /apps/{appId}/{collection}/{docId} {
      // Owner: full access
      allow read, write: if request.auth != null
        && resource != null
        && resource.data.owner_id == request.auth.uid;

      // Any project member can read tasks/meetings linked to shared projects
      // (client-side filter handles further scoping)
      allow read: if request.auth != null;

      // Create new documents
      allow create: if request.auth != null && resource == null;
    }

    // ─── Collection-level list (Firestore query support) ───────────────────
    match /apps/{appId}/{collection} {
      allow list: if request.auth != null;
    }
  }
}
